# Copy this file to .env and fill in your values

# ── OpenAI (leave blank if using Ollama only) ────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# ── Ollama / local LLM ────────────────────────────────────────────────────────
# Make sure Ollama is running: https://ollama.com
# Then pull the model: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# ── Default provider: "openai" or "ollama" ────────────────────────────────────
DEFAULT_PROVIDER=openai

# ── Local models (downloaded automatically on first run) ─────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Retrieval settings ────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5
MAX_CONTEXT_CHARS=4000
MAX_REFLECTION_RETRIES=2

# ── Storage ───────────────────────────────────────────────────────────────────
# base directory for all data; defaults to ./data
DATA_ROOT=./data
UPLOAD_FOLDER=${DATA_ROOT}/uploads        # files dropped by users
DATABASE_ROOT=${DATA_ROOT}/databases

# within the database root you can organise by type:
#   vector_db/      (dense retrieval)
#     chroma_db/     (Chroma collection files)
#     faiss_db/      (FAISS index files)
#   graph_db/       (graph_store.pkl)
#   keyword_db/     (bm25_store.pkl)
# you can override individual paths if desired:
CHROMA_PATH=${DATABASE_ROOT}/vector_db/chroma_db
FAISS_PATH=${DATABASE_ROOT}/vector_db/faiss_db
GRAPH_PATH=${DATABASE_ROOT}/graph_db/graph_store/graph_store.pkl
BM25_PATH=${DATABASE_ROOT}/keyword_db/bm25_store/bm25_store.pkl

# choose which vector store backend to use; supported values are "chroma" or "faiss"
VECTOR_BACKEND=chroma

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=true
FRONTEND_URL=http://localhost:5173
