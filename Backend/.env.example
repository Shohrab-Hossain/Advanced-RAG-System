# Copy this file to .env and fill in your values

# ── OpenAI (leave blank if using Ollama only) ────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# ── Ollama / local LLM ────────────────────────────────────────────────────────
# Make sure Ollama is running: https://ollama.com
# Then pull the model: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# ── Default provider: "openai" or "ollama" ────────────────────────────────────
DEFAULT_PROVIDER=openai

# ── Local models (downloaded automatically on first run) ─────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Retrieval settings ────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5
MAX_CONTEXT_CHARS=4000
MAX_REFLECTION_RETRIES=2

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_FOLDER=./data/uploads
CHROMA_PATH=./data/chroma_db
GRAPH_PATH=./data/graph_store.pkl
BM25_PATH=./data/bm25_store.pkl

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=true
FRONTEND_URL=http://localhost:5173
